# Backend Environment Configuration
# Copy this to .env.local in the duality_aii/ directory

# ============================================================================
# ML MODEL CONFIGURATION
# ============================================================================

# Path to the segmentation head checkpoint
# Set to absolute path or relative to inference_server.py location
MODEL_CHECKPOINT=./segmentation_head.pth

# Optional: Path to class names JSON file
# If not provided, uses default Falcon Desert class names
CLASS_NAMES_JSON=./class_names.json

# PyTorch device: 'cuda' (GPU) or 'cpu'
# Leave empty for automatic detection (prefers CUDA if available)
DEVICE=cuda

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Port to run inference server on
API_PORT=8000

# Host to bind to (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# ============================================================================
# FILE STORAGE
# ============================================================================

# Directory to store uploaded images (temporary)
UPLOAD_DIR=./uploads

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
