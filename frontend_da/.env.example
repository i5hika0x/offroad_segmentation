# Frontend Environment Configuration
# Copy relevant settings to .env.local for local development

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Base URL for the ML inference API
# Local Development: http://localhost:8000
# Production (civic backend): https://civic-backend.example.com/api/v1
VITE_API_BASE=http://localhost:8000

# API request timeout in milliseconds
VITE_API_TIMEOUT=60000

# ============================================================================
# DEVELOPMENT SERVER
# ============================================================================

# Development server port
VITE_PORT=5173

# Development server host
VITE_HOST=localhost

# ============================================================================
# APPLICATION FEATURES
# ============================================================================

# Enable debug mode (verbose logging in browser console)
VITE_DEBUG=false

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# Demo mode
VITE_DEMO_MODE=true

# ============================================================================
# FOR FUTURE USE (civic Backend Integration)
# ============================================================================

# When civic backend is ready, update VITE_API_BASE:
# VITE_API_BASE=https://civic-api.example.com/v1
#
# Authentication token (if required by civic backend):
# VITE_API_KEY=your_api_key_here
